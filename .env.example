# =============================================================================
# API server (@workspace/api-server) — set in Replit Secrets or local .env
# =============================================================================

# Required today by @workspace/db (Postgres connection string).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# HTTP port for the Express API (Replit sets this automatically in many templates).
PORT=5000

# Cursor Cloud Agents API key (from https://cursor.com/dashboard → Cloud Agents).
CURSOR_API_KEY=cursor_...

# Public Git repository URL that Cursor cloud agents can clone (must match your app source).
CURSOR_CLOUD_REPO_URL=https://github.com/your-org/your-repo

# Optional: branch or ref for cloud agent checkout (default: main).
CURSOR_CLOUD_REPO_REF=main

# Shared secret for MCP routes and MCP Authorization header from Cursor / SDK.
# Generate a long random string; use the same value wherever you configure Bearer auth.
MCP_SECRET=replace-with-long-random-secret

# Public HTTPS URL of the MCP **SSE** endpoint (no trailing slash after path).
# Example on Replit: https://YOUR-REPL.your-username.repl.co/api/mcp/sse
PUBLIC_MCP_URL=https://YOUR-REPL-HOST/api/mcp/sse

# Optional: public site URL for documentation / links only.
PUBLIC_APP_URL=https://YOUR-REPL-HOST

# Optional: if set, POST /api/agent requires Authorization: Bearer <same value>.
# Duplicate into VITE_AGENT_API_SECRET for the Vite app when using the in-browser coach.
AGENT_API_SECRET=

# =============================================================================
# Vite frontend (@workspace/fitness-tracker) — build-time / Replit env
# =============================================================================

# Origin of the API when the UI is not same-origin (local dev: http://localhost:5000).
VITE_API_BASE_URL=

# Optional: must match AGENT_API_SECRET when that variable is set (exposed in browser bundle).
VITE_AGENT_API_SECRET=
